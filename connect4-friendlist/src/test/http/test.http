### LOGIN (IntelliJ speichert Token automatisch!)
POST http://localhost:9001/api/v1/auth/login
Content-Type: application/json

{
  "username": "florian",
  "password": "1234"
}
> {%
    const cookies = response.headers.valuesOf("set-cookie");
    const accessTokenMatch = cookies[0].match("ACCESS_TOKEN=([^;]+)");
    client.global.set("access_token", accessTokenMatch[1]);
    client.log("✅ Token extrahiert: " + client.global.get("access_token"));
%}

